        "# Adicionar features polinomiais manualmente\n",
        "df['x_squared'] = df['x'] ** 2\n",
        "print(f\"\\n✅ Features criadas: x, x²\")\n",
        "\n",
        "# Separar features e target\n",
        "X_features = df[['x', 'x_squared']].values\n",
        "y_target = df['y_com_ruido'].values\n",
        "\n",
        "print(f\"\\n🔢 Dimensões dos dados:\")\n",
