        "# Calcular derivada numérica da função aprendida\n",
        "def derivada_numerica(x, modelo, scaler_X, scaler_y, h=1e-5):\n",
        "    \"\"\"Calcula a derivada numérica da função aprendida\"\"\"\n",
        "    # Ponto original\n",
        "    x_original = np.array([[x, x**2]])\n",
        "    x_scaled = scaler_X.transform(x_original)\n",
        "    y_scaled = modelo.predict(x_scaled, verbose=0)\n",
        "    y_original = scaler_y.inverse_transform(y_scaled)[0, 0]\n",
        "\n",
        "    # Ponto perturbado\n",
        "    x_perturbado = np.array([[x + h, (x + h)**2]])\n",
        "    x_perturbado_scaled = scaler_X.transform(x_perturbado)\n",
        "    y_perturbado_scaled = modelo.predict(x_perturbado_scaled, verbose=0)\n",
        "    y_perturbado = scaler_y.inverse_transform(y_perturbado_scaled)[0, 0]\n",
        "\n",
        "    # Derivada numérica\n",
        "    derivada = (y_perturbado - y_original) / h\n",
        "\n",
