        "# ========== 3. PRÉ-PROCESSAMENTO DOS DADOS ==========\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"3. PRÉ-PROCESSAMENTO DOS DADOS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Criar DataFrame para análise\n",
        "df = pd.DataFrame({\n",
