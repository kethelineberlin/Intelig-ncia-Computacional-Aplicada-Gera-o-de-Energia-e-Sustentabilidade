        "# ========== 2. DEFINIÇÃO DA FUNÇÃO E GERAÇÃO DE DADOS ==========\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"2. DEFINIÇÃO DA FUNÇÃO E GERAÇÃO DE DADOS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Função quadrática original\n",
        "def funcao_quadratica(x):\n",
        "    \"\"\"Calcula y = 2x² - 3x + 7\"\"\"\n",
        "    return 2*x**2 - 3*x + 7\n",
        "\n",
        "print(\"📊 Função definida: y = 2x² - 3x + 7\")\n",
        "\n",
        "# Gerar dados sintéticos\n",
        "np.random.seed(42)  # Para reproduzibilidade\n",
        "\n",
        "# Gerar valores de x\n",
        "x_min, x_max = -10, 10\n",
        "n_amostras = 1000\n",
        "\n",
        "X = np.random.uniform(x_min, x_max, n_amostras).reshape(-1, 1)\n",
        "\n",
        "# Calcular y verdadeiro (sem ruído)\n",
        "y_verdadeiro = funcao_quadratica(X)\n",
        "\n",
        "# Adicionar ruído gaussiano para simular dados do mundo real\n",
        "ruido = np.random.normal(0, 5, y_verdadeiro.shape)\n",
        "y_com_ruido = y_verdadeiro + ruido\n",
        "\n",
        "print(f\"\\n📈 Dados gerados:\")\n",
        "print(f\"• Intervalo de x: [{x_min}, {x_max}]\")\n",
        "print(f\"• Número de amostras: {n_amostras}\")\n",
        "print(f\"• Formato de X: {X.shape}\")\n",
        "print(f\"• Formato de y: {y_com_ruido.shape}\")\n",
        "print(f\"• Intensidade do ruído: σ = 5\")\n",
        "\n",
        "# Visualizar função original e dados\n",
        "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
        "\n",
        "# Plot 1: Função original vs dados\n",
        "x_plot = np.linspace(x_min, x_max, 1000).reshape(-1, 1)\n",
        "y_plot = funcao_quadratica(x_plot)\n",
        "\n",
        "axes[0].scatter(X[:100], y_com_ruido[:100], alpha=0.6, s=30,\n",
        "                label='Dados com ruído (amostra)', color='blue')\n",
        "axes[0].plot(x_plot, y_plot, 'r-', linewidth=3, label='Função verdadeira: y = 2x² - 3x + 7')\n",
