        "        tape.watch(X_tensor)\n",
        "        predictions = model(X_tensor)\n",
        "        # Usar a previsão da classe mais provável\n",
        "        class_idx = tf.argmax(predictions, axis=1)\n",
        "        selected_preds = tf.gather(predictions, class_idx, batch_dims=1)\n",
        "\n",
        "    gradients = tape.gradient(selected_preds, X_tensor)\n",
        "    importance = tf.reduce_mean(tf.abs(gradients), axis=0).numpy()\n",
        "\n",
        "    return importance\n",
