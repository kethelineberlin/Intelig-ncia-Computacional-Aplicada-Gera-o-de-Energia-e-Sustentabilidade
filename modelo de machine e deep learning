        "def compute_gradient_importance(model, X_sample, feature_names):\n",
        "    \"\"\"Calcula importância das features baseada em gradientes\"\"\"\n",
        "    X_tensor = tf.convert_to_tensor(X_sample, dtype=tf.float32)\n",
